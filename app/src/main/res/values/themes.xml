<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.NotesTaking" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:statusBarColor">@color/splash_background</item>    </style>

    <style name="Theme.NotesTaking.Splash" parent="Theme.NotesTaking">
        <item name="android:windowBackground">@color/splash_background</item>

        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@android:color/transparent</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/splash_background</item>

        <item name="android:windowFullscreen">true</item>
    </style>
</resources>